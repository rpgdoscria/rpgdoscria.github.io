{
  "name": "rpg-wiki-api",
  "version": "1.0.0",
  "private": true,
  "description": "Backend da Wiki RPG colaborativa (Cloudflare Workers + Hono + D1 + R2).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create rpg-wiki-db",
    "db:migrate:local": "wrangler d1 migrations apply rpg-wiki-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply rpg-wiki-db --remote",
    "db:query:local": "wrangler d1 execute rpg-wiki-db --local --command",
    "db:query:remote": "wrangler d1 execute rpg-wiki-db --remote --command",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.94.0"
  }
}
